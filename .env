# منفذ تشغيل السيرفر الافتراضي
PORT=8080

# مستويات تسجيل الأحداث والتتبع (Logging Levels)
RUST_LOG=doumdeli_business=debug,tower_http=debug,sqlx=info

# رابط الاتصال بقاعدة بيانات PostgreSQL المحلية (Localhost)
DATABASE_URL=postgres://postgres:secure_password_2026@localhost:5432/doumdeli_db

# مفتاح التشفير السري الخاص بتوليد والتحقق من توقيع الـ JWT Tokens
JWT_SECRET=super_secure_and_extremely_long_secret_key_2026_doumdeli_business_backend

# مدة صلاحية الـ Token بالدقائق (1440 دقيقة = 24 ساعة كاملة)
JWT_LIFETIME_MINUTES=1440
